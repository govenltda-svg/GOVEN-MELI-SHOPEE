{
  "buildCommand": "echo 'no build needed'",
  "outputDirectory": "public",
  "crons": [
    {
      "path": "/api/cron/sync-all",
      "schedule": "0 9 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" }
      ]
    }
  ]
}
